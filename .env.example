# Copy to .env and set a strong secret. The Next app must send this same
# value as:  Authorization: Bearer <API_KEY>
API_KEY=change-me-to-a-long-random-secret

# --- optional overrides (sensible defaults already applied) ---
# RETENTION_DAYS=7        # auto-delete finished jobs after N days (0=keep)
# RENDER_DPI=300          # rasterisation DPI
# MAX_PAGES=300           # reject PDFs with more pages
# MAX_UPLOAD_MB=300       # reject uploads larger than this
# MODEL_ID=nanonets/Nanonets-OCR2-3B
