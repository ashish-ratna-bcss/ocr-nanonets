# Copy to .env and set a strong secret. Every client must send this same
# value as:  Authorization: Bearer <API_KEY>
# Generate one:  openssl rand -hex 32
API_KEY=change-me-to-a-long-random-secret

# --- CORS (cross-origin browser access) -------------------------------------
# Dev / server-to-server: leave as "*" (any origin allowed).
# Production browser apps: comma-separated allowlist, e.g.
#   CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*
# Only set true if a client sends cookies. Ignored when CORS_ORIGINS=* (the
# CORS spec forbids credentials with a wildcard origin). Bearer-key auth does
# NOT need this.
# CORS_ALLOW_CREDENTIALS=false

# --- public ports (host side; nginx terminates TLS) -------------------------
# HTTPS_PORT=443
# HTTP_PORT=80           # plain HTTP, redirects to HTTPS

# --- optional overrides (sensible defaults already applied) ------------------
# RETENTION_DAYS=7        # auto-delete finished jobs after N days (0=keep)
# RENDER_DPI=300          # rasterisation DPI
# MAX_PAGES=300           # reject PDFs with more pages
# MAX_UPLOAD_MB=300       # reject uploads larger than this
# MODEL_ID=nanonets/Nanonets-OCR2-3B
